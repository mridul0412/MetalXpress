# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/metalxpress"

# ── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET="change-this-to-a-random-64-char-string-in-production"
ADMIN_PASSWORD="admin123"

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"
APP_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:5173"

# ── Live Metal Prices ─────────────────────────────────────────
# Option 1 (RECOMMENDED): metals-api.com — Real LME spot prices
# Sign up at https://metals-api.com → copy your Access Key below
# Free tier: 50 req/month | Starter: $15/month (500 req) | Business: $99/month
METALS_API_KEY="your_metals_api_key_here"

# Option 2 (DEFAULT fallback): Yahoo Finance + Stooq — Free, no key required
# Automatically used when METALS_API_KEY is not set or is the placeholder above

# ── Google OAuth ──────────────────────────────────────────────
# Sign up at https://console.cloud.google.com → Create project → APIs & Services → Credentials
# Create OAuth 2.0 Client ID (Web application)
# Authorized redirect URIs: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ── SMS OTP ───────────────────────────────────────────────────
# MSG91 (recommended for India): https://msg91.com → Sign up → Auth Key
# Setup: Create a Flow → add SMS step: "Your MetalXpress OTP is ##otp##. Valid for 10 minutes."
# DEV MODE: If these are not set, OTP is logged to console and hardcoded to 1234
MSG91_API_KEY="your_msg91_api_key"
MSG91_TEMPLATE_ID="your_msg91_template_id"

# ── Email (Verification + Password Reset) ─────────────────────
# Resend: https://resend.com → Sign up (free, 3000 emails/month)
# → API Keys → Create Key → paste below
# For EMAIL_FROM: use "MetalXpress <onboarding@resend.dev>" for testing
#   OR verify your domain at resend.com/domains and use "MetalXpress <noreply@metalxpress.in>"
# DEV MODE: If RESEND_API_KEY is not set, emails are logged to console only (no real sends)
RESEND_API_KEY="your_resend_api_key"
EMAIL_FROM="MetalXpress <onboarding@resend.dev>"

# ── Payments (Razorpay) ───────────────────────────────────────
# Sign up at https://razorpay.com → Settings → API Keys → Generate Key
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# ── File Uploads (Cloud Storage for Production) ───────────────
# CURRENT DEFAULT: Files saved to backend/uploads/ (local disk).
#   Works for local dev and MVP. NOT suitable for Railway/Heroku/Render
#   (stateless containers wipe the disk on every deploy).
#
# PRODUCTION OPTION A — Cloudinary (recommended):
#   npm install cloudinary multer-storage-cloudinary
#   Sign up at https://cloudinary.com (free tier: 25GB storage, 25GB/month bandwidth)
#   Then update the multer config in backend/src/routes/marketplace.js
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
#
# PRODUCTION OPTION B — AWS S3:
#   npm install @aws-sdk/client-s3 multer-s3
#   Create S3 bucket → IAM user with S3 access → copy keys below
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="metalxpress-uploads"

# ── Subscription (Pro access override for dev/testing) ────────
PRO_EMAILS="test@metalxpress.in,admin@metalxpress.in"

# ── Redis (optional, not currently used) ─────────────────────
# REDIS_URL="redis://localhost:6379"

# ── Legacy (unused) ──────────────────────────────────────────
# LME_API_KEY="demo"
# LME_API_URL="https://metals-api.com/api"
