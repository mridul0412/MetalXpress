{
  "name": "BhavX Development",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "username": "node"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postAttachCommand": "bash .devcontainer/welcome.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnSave": false,
        "files.exclude": {
          "**/node_modules": true,
          "**/.git": true
        }
      }
    }
  },
  "forwardPorts": [3001, 5173],
  "portsAttributes": {
    "3001": { "label": "Backend (Express)", "onAutoForward": "silent" },
    "5173": { "label": "Frontend (Vite)", "onAutoForward": "openBrowser" }
  },
  "remoteUser": "node",
  "mounts": [],
  "containerEnv": {
    "BHAVX_CODESPACE": "true"
  }
}
